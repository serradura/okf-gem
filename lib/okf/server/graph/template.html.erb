   <!-- INDEX -->
   <section class="view" id="view-index">
    <div class="pad">
     <div class="shead"><h2>Index</h2><span class="cnt" id="ix-cnt"></span></div>
     <p class="viewnote">The bundle's own maps, directory by directory: the authored <code>index.md</code> where one exists, or the listing synthesized from the concepts there (§6). Click an entry to open it in the graph.</p>
     <div id="ix-list"><p class="empty">Loading the map…</p></div>
