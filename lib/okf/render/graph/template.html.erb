<script src="https://cdn.jsdelivr.net/npm/cytoscape@3.30.2/dist/cytoscape.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked@14/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
<style>
/* ═══ CSS sections, in file order ═══════════════════════════════════════════
   Each is opened by a `── name ──` banner; `grep -n '── ' template.html.erb`
   prints this list with current line numbers, which is the reliable version.

     app shell: rail + main        main column
     shared controls               section head
     chips / badges                graph view
     filters slide-over            inspector content
     markdown body                 fullscreen diagram viewer
     bundle switcher (hub)         the ? sheet
     bundle-count badge (hub)      mobile nav + first-visit note
     catalog                       files
     tags                          stats
     type autocomplete             synthesized-map listing
     ≤768px compact chrome         ≥769px pane folding

   The last two rebuild the layout at a breakpoint and are checked by
   test/browser/specs/responsive.spec.js — computed style at a real viewport
   width, which is the only way that block can be checked at all.
   ═════════════════════════════════════════════════════════════════════════ */
 :root{
  --bg:#ffffff; --panel:#ffffff; --panel-2:#f6f7f8; --canvas:#f4f5f7; --ink:#1f2328; --ink-soft:#333333;
  --muted:#63697a; --faint:#9298a4; --line:#e6e8eb; --line-2:#eef0f2;
  --accent:#e21e1e; --accent-ink:#c81a1a; --accent-soft:#fdecec; --edge:#cfd4db; --ok:#1a9e5f;
  --rail:#15171c; --rail-ink:#8b919c; --rail-ink-hi:#dfe2e7;
  --shadow:0 1px 2px rgba(20,24,33,.05),0 8px 24px rgba(20,24,33,.07);
 }
 :root[data-theme=dark]{
  --bg:#17191e; --panel:#1d2026; --panel-2:#232833; --canvas:#111318; --ink:#eceef1; --ink-soft:#d7dae0;
  --muted:#9aa0aa; --faint:#6b7178; --line:#2a2e36; --line-2:#232830;
  --accent:#f5433b; --accent-ink:#ff726b; --accent-soft:#3a1f1e; --edge:#333c49; --ok:#37c07f;
  --rail:#0d0e11; --rail-ink:#868c98; --rail-ink-hi:#e2e5ea;
  --shadow:0 1px 2px rgba(0,0,0,.4),0 10px 28px rgba(0,0,0,.42);
 }
 @media (prefers-color-scheme:dark){:root:not([data-theme=light]){
  --bg:#17191e; --panel:#1d2026; --panel-2:#232833; --canvas:#111318; --ink:#eceef1; --ink-soft:#d7dae0;
  --muted:#9aa0aa; --faint:#6b7178; --line:#2a2e36; --line-2:#232830;
  --accent:#f5433b; --accent-ink:#ff726b; --accent-soft:#3a1f1e; --edge:#333c49; --ok:#37c07f;
  --rail:#0d0e11; --rail-ink:#868c98; --rail-ink-hi:#e2e5ea;
  --shadow:0 1px 2px rgba(0,0,0,.4),0 10px 28px rgba(0,0,0,.42);
 }}
 *{box-sizing:border-box}
 html,body{margin:0;height:100%}
 body{background:var(--bg);color:var(--ink);font:14px/1.55 'Poppins',system-ui,-apple-system,Segoe UI,Roboto,sans-serif;-webkit-font-smoothing:antialiased}
 @property --side-w{syntax:'<length>';inherits:true;initial-value:380px}
 h1,h2,h3,h4{margin:0}

 /* ── app shell: rail + main ── */
 #app{display:grid;grid-template-columns:76px 1fr;height:100vh;height:100dvh}
 #rail{grid-column:1;background:var(--rail);display:flex;flex-direction:column;align-items:center;gap:3px;padding:12px 8px;overflow:hidden}
 .rail-brand{width:34px;height:34px;margin:2px 0 10px;flex:none}
 .rail-brand svg{width:34px;height:34px;display:block}
 .rail-item{position:relative;width:60px;padding:9px 2px;border:0;background:none;border-radius:12px;cursor:pointer;
  display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--rail-ink);transition:background .15s,color .15s;font-family:inherit}
 .rail-item .ri-ico svg{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
 .rail-item .ri-lbl{font-size:10.5px;font-weight:500;letter-spacing:.005em}
 .rail-item:hover{color:var(--rail-ink-hi);background:rgba(255,255,255,.06)}
 .rail-item:focus-visible{outline:2px solid var(--accent);outline-offset:1px}
 .rail-item.active{color:#fff}
 .rail-item.active .ri-ico{color:var(--accent)}
 .rail-item.active::before{content:"";position:absolute;left:-8px;top:50%;transform:translateY(-50%);width:3px;height:24px;border-radius:0 3px 3px 0;background:var(--accent);
  transition:transform .18s cubic-bezier(.22,1,.36,1)}
 .rail-sp{flex:1}
 .rail-tools{display:flex;flex-direction:column;gap:6px;align-items:center}
 .rail-tools .btn{color:var(--rail-ink);border-color:transparent;background:rgba(255,255,255,.05)}
 .rail-tools .btn:hover{color:var(--rail-ink-hi);background:rgba(255,255,255,.1);border-color:transparent}

 /* ── main column ── */
 #main{grid-column:2;display:flex;flex-direction:column;min-width:0}
 #topbar{flex:none;display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--line);background:var(--panel)}
 /* on desktop the tools wrapper is layout-invisible — its children stay direct
    flex items of the bar; on mobile (below) it becomes the ⚙ drop-down sheet */
 #bar-tools{display:contents}
 /* the title may shrink and ellipsize at every width — mid-size viewports
    (portrait iPad Air/Pro run the desktop layout) must not overflow the bar */
 .ident{font-size:13.5px;font-weight:600;color:var(--ink);white-space:nowrap;letter-spacing:-.01em;min-width:0;overflow:hidden;text-overflow:ellipsis}
 .ident .muted{color:var(--muted);font-weight:400;margin-left:9px;font-size:12.5px}
 .ident .src{color:var(--accent-ink);text-decoration:none;margin-left:8px}
 .ident .src:hover{text-decoration:underline}
 /* overflow:hidden is load-bearing, not tidiness: a slide-over parked or
    *animating* off the right edge widens the document unless something clips
    it, and #views is the containing block for any panel that belongs to more
    than one view. #stage has always done this job for the Filters panel, which
    is exactly why that one never showed the bug. */
 #views{flex:1;min-height:0;position:relative;background:var(--bg);overflow:hidden}
 .view{position:absolute;inset:0;display:none;flex-direction:column;min-height:0}
 .view.active{display:flex}

 /* ── shared controls ── */
 .field{height:34px;border:1px solid var(--line);border-radius:9px;background:var(--panel);color:var(--ink);
  font:inherit;font-size:13px;padding:0 10px;outline:none;transition:border-color .15s,box-shadow .15s}
 .field:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
 .field::placeholder{color:var(--muted)}
 /* iOS Safari zooms the page whenever a focused control is under 16px, and it
    never zooms back out — so every `/` left the reader pinching. 16px is the
    whole fix; `maximum-scale=1` would also stop it and is the wrong trade, since
    it takes pinch-zoom away from everyone to spare one gesture.
    Both conditions, because neither covers the other: a phone is narrow, and a
    tablet in landscape is not — but it still zooms. Desktop keeps 13px. */
 @media (max-width:768px),(pointer:coarse){
  .field{font-size:16px}
 }
 .search{position:relative;display:flex;align-items:center;flex:1 1 320px;min-width:130px;max-width:520px}
 .search svg{position:absolute;left:11px;width:15px;height:15px;stroke:var(--muted);fill:none;stroke-width:1.8;pointer-events:none}
 .search input{width:100%;padding-left:33px;padding-right:52px}
 /* the count only exists while filtering, so the room for it is claimed only then */
 .search.has-cnt input{padding-right:104px}
 /* ── the search box's right-edge tools: the live match count, and the chip
       that names the palette. The box filters what is on screen and the palette
       finds across every bundle — two grammars behind one look — so the second
       one is advertised inside the first, where the reader already is when the
       filter disappoints them. ── */
 .s-tools{position:absolute;right:7px;top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:8px}
 .s-cnt{font-size:11px;color:var(--faint);font-variant-numeric:tabular-nums;white-space:nowrap;pointer-events:none}
 .s-cnt[hidden]{display:none}
 .s-kbd{cursor:pointer;border:1px solid var(--line);border-radius:6px;background:var(--panel-2);color:var(--muted);
  font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:10.5px;font-weight:600;letter-spacing:.02em;
  line-height:1;padding:4px 6px;transition:color .15s,border-color .15s}
 .s-kbd:hover{color:var(--ink);border-color:var(--accent)}
 .s-kbd:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
 /* the bridge: the local filter came up empty, so say so and offer the way on —
    same surface language as the palette it hands over to */
 .s-bridge{position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:60;background:var(--panel);border:1px solid var(--line);
  border-radius:11px;box-shadow:var(--shadow);padding:11px 13px;font-size:12.5px}
 .s-bridge[hidden]{display:none}
 .sb-msg{color:var(--muted);margin-bottom:9px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .sb-msg b{color:var(--ink);font-weight:600}
 .sb-row{display:flex;gap:8px;flex-wrap:wrap}
 .sb-act{cursor:pointer;display:inline-flex;align-items:center;gap:7px;font-family:inherit;font-size:12px;padding:5px 10px;
  border:1px solid var(--line);border-radius:8px;background:var(--panel-2);color:var(--muted);transition:color .15s,border-color .15s}
 .sb-act:hover{color:var(--ink);border-color:var(--accent)}
 .sb-act[hidden]{display:none}
 .sb-act.primary{color:var(--accent-ink);border-color:var(--accent);background:var(--accent-soft)}
 .sb-act kbd{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:10px;color:var(--faint);
  border:1px solid var(--line);border-radius:4px;padding:1px 4px;background:var(--panel);line-height:1.3}
 .selwrap{position:relative;display:inline-flex;flex:none}
 /* `display:inline-flex` above outranks the [hidden] attribute's own
    display:none, so the depth select would sit in the bar unclustered. */
 .selwrap[hidden]{display:none}
 /* the depth control is a single digit — sized to its content, not to the
    layout select beside it */
 #cluster-depth{padding-right:26px;min-width:0}
 .selwrap::after{content:"";position:absolute;right:12px;top:50%;width:7px;height:7px;border-right:1.6px solid var(--muted);border-bottom:1.6px solid var(--muted);transform:translateY(-70%) rotate(45deg);pointer-events:none}
 select.field{appearance:none;-webkit-appearance:none;padding-right:30px;cursor:pointer}
 select.field:disabled{opacity:.45;cursor:not-allowed}
 .btn{cursor:pointer;display:inline-grid;place-items:center;width:34px;height:34px;border-radius:9px;border:1px solid var(--line);
  background:var(--panel);color:var(--muted);transition:color .15s,border-color .15s,background .15s;font-family:inherit;position:relative}
 .btn:hover{color:var(--ink);border-color:var(--accent)}
 .btn:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
 .btn[aria-pressed=true]{color:var(--accent);border-color:var(--accent);background:var(--accent-soft)}
 .btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
 .btn[hidden]{display:none}
 .btn.text{width:auto;display:inline-flex;align-items:center;padding:0 12px;gap:7px;font-size:13px;font-weight:500;color:var(--ink)}
 /* `.btn.text` sets display, which outranks `.btn[hidden]` above at equal
    specificity — so hiding a text button (e.g. #fp-graph on a log) needs its own
    [hidden] rule to win, same as .fp-head[hidden] does below. */
 .btn.text[hidden]{display:none}
 .btn .fbadge{position:absolute;top:-6px;right:-6px;min-width:16px;height:16px;padding:0 4px;border-radius:9px;background:var(--accent);
  color:#fff;font-size:10px;font-weight:600;display:none;place-items:center;line-height:1}
 .btn.on-filter .fbadge{display:grid}
 #graph-controls{display:none;align-items:center;gap:9px}
 #app[data-view=graph] #graph-controls{display:flex}
 #file-controls{display:none;align-items:center;gap:8px}
 #app[data-view=files] #file-controls{display:flex}
 /* the mobile controls toggle — the ≤768px block turns the control groups into
    a drop-down sheet behind this button, so the topbar never overflows */
 #btn-controls{display:none;flex:none}
 #btn-controls[aria-expanded=true]{color:var(--accent);border-color:var(--accent);background:var(--accent-soft)}
 #search-wrap{display:flex;flex:1}
 /* Stats is the one view that does not filter, so it hides the box rather than
    offering a dead one. Mirrors SEARCH_PH in the script — a view listed there
    shows it — and "index" needs no rule of its own: it is the files view on
    another tab, and filters as files. */
 #app[data-view=stats] #search-wrap{visibility:hidden}
 #btn-theme .sun{display:none} :root[data-theme=dark] #btn-theme .sun{display:block} :root[data-theme=dark] #btn-theme .moon{display:none}
 #btn-full .compress{display:none} #btn-full[aria-pressed=true] .compress{display:block} #btn-full[aria-pressed=true] .expand{display:none}

 /* ── section head with the whysimplicity red underline ── */
 .shead{display:flex;align-items:baseline;gap:12px;margin:0 0 16px}
 .shead h2{font-size:17px;font-weight:600;letter-spacing:-.01em;position:relative;padding-bottom:7px}
 .shead h2::after{content:"";position:absolute;left:0;bottom:0;width:34px;height:3px;border-radius:3px;background:var(--accent)}
 .shead .cnt{font-size:12.5px;color:var(--faint)}

 /* ── chips / badges ── */
 .chip{display:inline-flex;align-items:center;gap:7px;padding:5px 11px;border-radius:999px;font-size:12.5px;
  color:var(--muted);background:var(--panel);border:1px solid var(--line);cursor:pointer;user-select:none;transition:.14s;font-family:inherit}
 .chip:hover{color:var(--ink);border-color:var(--accent)}
 .chip.on{background:var(--accent);border-color:var(--accent);color:#fff}
 .chip .dot{width:9px;height:9px;border-radius:50%} .chip .c{color:var(--faint);font-variant-numeric:tabular-nums}
 .chip.on .c{color:rgba(255,255,255,.8)}
 .badge{display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:600;letter-spacing:.02em;color:var(--ink);
  background:var(--line-2);border:1px solid var(--line);border-radius:7px;padding:3px 9px}
 .badge .dot{width:8px;height:8px;border-radius:50%}
 .status{font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;padding:2px 7px;border-radius:5px;color:var(--muted);background:var(--line-2)}
 .status.shipped{color:var(--ok);background:color-mix(in srgb,var(--ok) 14%,transparent)}
 .tag{background:var(--line-2);border:1px solid var(--line);border-radius:6px;padding:2px 8px;font-size:11px;color:var(--muted)}

 /* ── graph view ── */
 .graph-body{display:grid;grid-template-columns:1fr var(--side-w);height:100%;min-height:0;
  --side-w:var(--side-w-user,380px);transition:--side-w .22s cubic-bezier(.22,1,.36,1)}
 .graph-body[data-side=hidden]{--side-w:0px}
 /* the chevron is a preset, not a maximum — the resizer goes wider on demand,
    so it splits the screen rather than burying the graph */
 .graph-body[data-side=wide]{--side-w:50vw}
 .graph-body.side-drag{transition:none}
 #stage{position:relative;min-width:0;overflow:hidden;background:var(--canvas)}
 #cy{position:absolute;inset:0}
 .ghint{position:absolute;right:16px;bottom:14px;z-index:3;font-size:11px;color:var(--faint);pointer-events:none}
 #side{position:relative;min-width:0;background:var(--panel);border-left:1px solid var(--line);display:flex;flex-direction:column;overflow:hidden}
 .graph-body[data-side=hidden] #side{border-left:0}
 /* drag handle on the panel's left edge (double-click resets the width) */
 #side-resizer{position:absolute;left:0;top:0;bottom:0;width:7px;cursor:col-resize;z-index:4;touch-action:none}
 #side-resizer::after{content:"";position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--accent);opacity:0;transition:opacity .15s}
 #side-resizer:hover::after,.graph-body.side-drag #side-resizer::after{opacity:.7}
 .graph-body[data-side=hidden] #side-resizer{display:none}
 #side-head{display:flex;align-items:center;gap:6px;padding:9px 12px;border-bottom:1px solid var(--line);flex:none}
 #side-head .lbl{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--faint);margin-right:auto}
 #side-head .btn{width:30px;height:30px}
 #side-body{padding:16px 18px;overflow:auto;flex:1}

 /* ── filters slide-over (graph + catalog) ── */
 .slideover{position:absolute;top:0;right:0;bottom:0;width:300px;max-width:82%;z-index:6;background:var(--panel);
  border-left:1px solid var(--line);box-shadow:var(--shadow);display:flex;flex-direction:column;
  transform:translateX(100%);transition:transform .2s cubic-bezier(.22,1,.36,1)}
 .slideover.open{transform:none}
 .slideover .fhead{display:flex;align-items:center;gap:8px;padding:12px 14px;border-bottom:1px solid var(--line)}
 .slideover .fhead h3{font-size:13px;font-weight:600;margin-right:auto}
 .slideover .fbody{padding:14px;overflow:auto;flex:1}
 .slideover .fgroup{margin-bottom:18px}
 .slideover .fgroup h4{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--faint);margin:0 0 9px}
 .slideover .fchips{display:flex;flex-wrap:wrap;gap:6px}
 .cat-types{align-items:center;gap:10px} .cat-types #cat-types{display:flex;flex-wrap:wrap;gap:7px}
 .link{background:none;border:0;color:var(--accent-ink);font:inherit;font-size:12.5px;cursor:pointer;padding:0;font-weight:500}
 .link:hover{text-decoration:underline}

 /* ── bundles slide-over (⚙ in the rail) ──
    The registry, surfaced on the page, so choosing which bundle `/` opens no
    longer means leaving the graph for /b/ — and knowing /b/ exists. --warn is
    the one added hue; ok and error reuse --ok and --accent-ink, so the health
    trio stays the page's own. ── */
 :root{--warn:#9a6700}
 :root[data-theme=dark]{--warn:#d4a72c}
 a.rail-brand{display:block;cursor:pointer;border-radius:9px}
 a.rail-brand:focus-visible{outline:2px solid var(--accent);outline-offset:3px}
 #ws-ovl{position:absolute;inset:0;z-index:5;background:rgba(15,17,22,.28)}
 #ws-ovl[hidden]{display:none}
 #ws{width:340px}
 /* Parked off-canvas, a slide-over STILL OCCUPIES LAYOUT — and #views does not
    clip, which the Filters panel only gets away with because #stage does. The
    closed panel widened the document by its own 340px: a horizontal scrollbar
    on every page, from a panel nobody had opened. So it is out of the box
    entirely while closed; display is restored one frame before .open so the
    slide still animates, and taken away again once the slide back has ended. */
 #ws[hidden]{display:none}
 .ws-head-t{margin-right:auto;min-width:0}
 .ws-sub{font-size:11px;color:var(--faint);margin-top:1px}
 #ws-flash{font-size:11.5px;color:var(--muted);background:var(--panel-2);border-bottom:1px solid var(--line);padding:7px 14px}
 #ws-flash[hidden]{display:none}
 #ws-flash.err{color:var(--accent-ink)}
 .ws-row{padding:11px 2px;border-bottom:1px solid var(--line-2);display:flex;align-items:flex-start;gap:8px}
 .ws-row:last-child{border-bottom:0}
 .ws-row-main{min-width:0;flex:1}
 .ws-t{display:flex;align-items:center;gap:8px;flex-wrap:wrap;min-width:0}
 .ws-title{font-size:13px;font-weight:600;color:var(--ink);background:none;border:0;padding:0;cursor:pointer;
  font-family:inherit;text-align:left;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .ws-title:hover{color:var(--accent-ink);text-decoration:underline}
 .ws-title.off{color:var(--faint);cursor:default}
 .ws-title.off:hover{color:var(--faint);text-decoration:none}
 .ws-pill{font-size:9.5px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;padding:1px 7px;
  border-radius:999px;border:1px solid var(--line);color:var(--muted);background:var(--line-2);flex:none}
 .ws-pill.def{color:var(--accent-ink);background:var(--accent-soft);border-color:transparent}
 .ws-meta{display:flex;align-items:center;gap:9px;font-size:11.5px;color:var(--muted);margin-top:3px;flex-wrap:wrap}
 .ws-slug{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;color:var(--faint)}
 .ws-health.ok{color:var(--ok)} .ws-health.warn{color:var(--warn)}
 .ws-health.error,.ws-health.missing{color:var(--accent-ink)}
 .ws-slug-edit{height:24px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11px;padding:0 7px;width:150px;border-radius:6px}
 /* One ⋯ per row, and the verbs inside it. Three same-weight text links under
    every row meant eighteen down the panel, none of which looked pressable and
    one of which was destructive in the same clothes as the harmless two. In a
    menu they can be ordered, separated and coloured by consequence. */
 .ws-menu-btn{flex:none;width:28px;height:26px;border-radius:7px;border:1px solid var(--line);background:var(--panel-2);
  color:var(--muted);cursor:pointer;display:grid;place-items:center;font-family:inherit;line-height:1;
  transition:color .15s,border-color .15s,background .15s}
 .ws-menu-btn:hover{color:var(--ink);border-color:var(--accent);background:var(--panel)}
 .ws-menu-btn[aria-expanded=true]{color:var(--accent-ink);border-color:var(--accent);background:var(--accent-soft)}
 .ws-menu-btn:focus-visible{outline:2px solid var(--accent);outline-offset:1px}
 .ws-menu-btn svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round}
 .ws-menu{position:absolute;z-index:8;min-width:180px;background:var(--panel);border:1px solid var(--line);
  border-radius:10px;box-shadow:var(--shadow);padding:5px;display:flex;flex-direction:column}
 .ws-menu[hidden]{display:none}
 .ws-menu button{display:flex;align-items:center;gap:9px;width:100%;padding:7px 9px;border:0;border-radius:7px;
  background:none;color:var(--ink);font:inherit;font-size:12.5px;cursor:pointer;text-align:left}
 .ws-menu button:hover{background:var(--line-2)}
 .ws-menu button:disabled{color:var(--faint);cursor:default;background:none}
 .ws-menu button.danger{color:var(--accent-ink)}
 .ws-menu button.danger:hover{background:var(--accent-soft)}
 .ws-menu .sep{height:1px;background:var(--line);margin:4px 2px}
 /* A rename and a removal both need a second thought, so both take over the row
    and state themselves — no armed link hiding a second meaning in its colour,
    and no timed revert asking the reader to be quick. */
 .ws-edit{margin-top:7px;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
 .ws-hint{font-size:10.5px;color:var(--faint);margin-top:5px}
 .ws-confirm{margin-top:7px;padding:9px 10px;border:1px solid var(--line);border-radius:8px;background:var(--panel-2)}
 .ws-confirm p{margin:0 0 8px;font-size:11.5px;color:var(--ink-soft);line-height:1.5}
 .ws-confirm .crow{display:flex;gap:8px}
 .btn-sm{height:26px;padding:0 10px;border-radius:7px;border:1px solid var(--line);background:var(--panel);
  color:var(--ink);font:inherit;font-size:12px;cursor:pointer}
 .btn-sm:hover{border-color:var(--accent)}
 .btn-sm.primary{background:var(--accent);border-color:var(--accent);color:#fff}
 .btn-sm.primary:hover{filter:brightness(1.07)}
 /* Read-only is a state to explain, not a set of controls to hide silently: the
    reader keeps every fact and gets one sentence naming who may change them. */
 .ws-ro-note{margin:0 0 4px;padding:9px 10px;border:1px solid var(--line);border-left:2px solid var(--warn);
  border-radius:8px;background:var(--panel-2);font-size:11.5px;color:var(--muted);line-height:1.55}
 .ws-ro-note code,.ws-empty code,.ws-foot code{background:var(--line-2);border:1px solid var(--line);padding:1px 5px;
  border-radius:5px;font-size:.92em;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:var(--ink-soft)}
 .ws-empty{margin:0;padding:22px 16px;font-size:12.5px;color:var(--muted);line-height:1.7;text-align:center}
 .ws-foot{border-top:1px solid var(--line);padding:11px 14px;font-size:11.5px;color:var(--muted);line-height:1.6}
 @media (max-width:768px){#ws{width:100%;max-width:100%}}

 /* ── inspector content ── */
 .type{display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:600;color:var(--ink);
  background:var(--line-2);border:1px solid var(--line);border-radius:7px;padding:3px 9px}
 .type .dot{width:9px;height:9px;border-radius:50%}
 .title{font-size:18px;font-weight:600;margin:.5em 0 0;letter-spacing:-.01em;line-height:1.3;text-wrap:balance}
 .desc{color:var(--muted);margin:10px 0 14px}
 .tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px}
 /* the inspector's type and tags are filter handles — clicking one focuses the
    graph on that facet, the same jump a stats bar makes. Real buttons, like
    .tcloud, so the keyboard reaches them for free; font-size stays with .type
    and .tag, which set their own and are the reason this rule sets neither. */
 .facet{cursor:pointer;font-family:inherit;line-height:inherit}
 .facet:hover{border-color:var(--accent);color:var(--accent-ink)}
 .facet.on{background:var(--accent);border-color:var(--accent);color:#fff}
 .rel{margin:14px 0 0}
 .rel h4{margin:0 0 5px;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--faint)}
 .rel h4 .c{margin-left:6px;font-variant-numeric:tabular-nums}
 /* A link row is a concept row, so it speaks the vocabulary .titem already uses
    in the tags view: the type's dot, the title, the type name trailing faint.
    The dot is the bullet that carries information — it is the colour the node
    already wears in the graph beside it, so the column reads as a map of the
    neighbourhood before a single title is.
    What makes these read as *links* is the container, not the colour. Accent
    text on every row spends the accent on nothing and leaves the eye no way in;
    ink text alone reads as prose. So the rows share one panel with hairline
    dividers and a hover fill — the affordance a menu has, carried by structure,
    which leaves colour free to mean type and nothing else. One box rather than
    .titem's per-row cards: at nine links in a side panel, six borders weigh
    more than the concepts do, and a single surface stays quiet. */
 .rellist{border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--panel-2)}
 .rel a{display:flex;align-items:center;gap:9px;padding:6px 10px;color:var(--ink);cursor:pointer;font-size:13px;text-decoration:none;transition:background .12s,color .12s}
 .rel a+a{border-top:1px solid var(--line)}
 .rel a:hover{background:var(--accent-soft);color:var(--accent-ink)}
 .rel a .dot{width:8px;height:8px;border-radius:50%;flex:none}
 .rel a .rt{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .rel a .ty{margin-left:auto;padding-left:8px;flex:none;font-size:11px;color:var(--faint)}
 .empty{color:var(--muted)} .empty b{color:var(--ink);font-weight:600} .loading{color:var(--faint)}

 /* ── markdown body ── */
 .body{border-top:1px solid var(--line);padding-top:14px;margin-top:16px;font-size:14px;line-height:1.62;color:var(--ink-soft)}
 .body>*:first-child{margin-top:0}
 .body h1{font-size:19px}.body h2{font-size:16px}.body h3{font-size:14px}.body h1,.body h2,.body h3{line-height:1.3;font-weight:600;margin:1.2em 0 .5em}
 .body a{color:var(--accent-ink)}
 #side-body a.dead,.fp-body a.dead{opacity:.55;cursor:not-allowed;text-decoration:line-through}
 .body code{background:var(--line-2);border:1px solid var(--line);padding:1px 5px;border-radius:5px;font-size:.85em;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
 .body pre{background:var(--line-2);border:1px solid var(--line);padding:12px;border-radius:10px;overflow:auto}
 .body pre code{background:none;border:0;padding:0}
 .body table{border-collapse:collapse;display:block;overflow:auto}
 .body td,.body th{border:1px solid var(--line);padding:5px 9px}
 .body img{max-width:100%}
 .body blockquote{margin:.6em 0;padding:.2em 0 .2em 14px;border-left:3px solid var(--line);color:var(--muted)}
 .mermaid{margin:14px 0;display:flex;justify-content:center;background:var(--panel-2);border:1px solid var(--line);border-radius:10px;padding:12px;overflow:auto;cursor:zoom-in}
 .mermaid:hover{border-color:var(--accent)}
 .mermaid:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
 .mermaid svg{max-width:100%;height:auto}

 /* ── fullscreen diagram viewer (Panzoom, lazy like Mermaid itself) ── */
 #dgv{position:fixed;inset:0;z-index:80;background:var(--canvas)}
 #dgv[hidden]{display:none}
 #dgv-stage{position:absolute;inset:0;overflow:hidden;touch-action:none;cursor:grab;display:flex;align-items:center;justify-content:center}
 #dgv-stage:active{cursor:grabbing}
 #dgv-pan{flex:none}
 #dgv-pan svg{display:block;max-width:none}
 .dgv-bar{position:absolute;top:14px;right:14px;display:flex;gap:8px;z-index:2}
 .dgv-bar .btn{background:var(--panel);box-shadow:var(--shadow)}
 .dgv-hint{position:absolute;bottom:14px;left:0;right:0;text-align:center;font-size:12px;color:var(--faint);pointer-events:none}
 /* ── bundle switcher (hub only) ── */
 #sw{position:fixed;inset:0;z-index:90;background:rgba(0,0,0,.34);display:flex;align-items:flex-start;justify-content:center;padding-top:14vh}
 #sw[hidden]{display:none}
 #sw-box{width:min(540px,92vw);background:var(--panel);border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);padding:12px}
 #sw-input{width:100%;box-sizing:border-box}
 #sw-list{list-style:none;margin:10px 0 0;padding:0;max-height:46vh;overflow:auto}
 #sw-list a{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:8px;color:var(--ink);text-decoration:none;font-size:14px}
 #sw-list a .slug{margin-left:auto;color:var(--faint);font-size:12px}
 #sw-list .sw-grp{margin:9px 0 3px;padding:0 10px;font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--faint)}
 #sw-list .sw-grp:first-child{margin-top:0}
 /* Under a hub a view is the sideline, so it sits at the muted weight until the
    cursor reaches it — present, never competing with the bundle you came for.
    Standalone drops the class: there, views are all there is to pick. */
 #sw-list a.sw-view{color:var(--muted)}
 #sw-list a.sw-view:hover,#sw-list a.sw-view.active{color:var(--ink)}
 /* The rail sets its own svg size, so the copy needs one here — smaller, since
    a palette row is not a 76px rail tile. currentColor is what the rail already
    draws with, which means the icon dims and lifts with the row for free. */
 #sw-list a .sw-ico{flex:none;display:flex;align-items:center}
 #sw-list a .sw-ico svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
 #sw-list a:hover,#sw-list a.active{background:var(--line-2)}
 #sw-list a.cur{color:var(--muted);cursor:default}
 #sw-list a.cur:hover{background:none}
 #sw-list a.none{color:var(--muted);cursor:default;font-size:13px}
 .sw-def{margin-left:7px;padding:1px 7px;border-radius:99px;background:var(--line-2);color:var(--muted);font-size:11px;vertical-align:1px}
 /* A concept hit is the one two-line row in the palette: a bundle or a view is
    a destination you already know the name of, a concept is one you are being
    shown evidence for. The snippet is that evidence, so it gets its own line
    rather than being squeezed onto the first. */
 #sw-list a.sw-hit{display:block;padding:8px 10px}
 #sw-list a.sw-hit .hit-top{display:flex;align-items:baseline;gap:8px}
 #sw-list a.sw-hit .hit-t{font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 #sw-list a.sw-hit .hit-type{color:var(--faint);font-size:11.5px;white-space:nowrap}
 #sw-list a.sw-hit .slug{margin-left:auto;flex:none}
 #sw-list a.sw-hit .hit-s{display:block;margin-top:2px;color:var(--muted);font-size:12.5px;line-height:1.45;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 /* The matched terms, marked where they landed. This is the only place the
    palette says *why* a row is here, so it takes the accent — muted enough to
    read as text, not as a highlighter pen. */
 #sw-list a.sw-hit mark{background:var(--accent-soft);color:var(--accent-ink);border-radius:3px;padding:0 1px}
 /* The async group: results arrive after the keystroke that asked for them, so
    the header carries the state instead of the list jumping to a spinner. */
 #sw-list .sw-grp .sw-state{margin-left:6px;font-weight:400;text-transform:none;letter-spacing:0}

 /* ── the ? sheet — same overlay shape as the palette, one row per binding ── */
 #kb{position:fixed;inset:0;z-index:91;background:rgba(0,0,0,.34);display:flex;align-items:flex-start;justify-content:center;padding-top:14vh}
 #kb[hidden]{display:none}
 #kb-box{width:min(420px,92vw);background:var(--panel);border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);padding:14px 16px 16px}
 #kb-head{display:flex;align-items:center;margin-bottom:12px}
 #kb-head h3{margin:0;font-size:13px;font-weight:600;letter-spacing:.02em}
 #kb-head .btn{margin-left:auto;width:28px;height:28px}
 /* the key column sizes to the widest chord, so every description starts on one
    line and the sheet reads as a table without drawing one */
 #kb-list{margin:0;display:grid;grid-template-columns:auto 1fr;gap:9px 14px;align-items:center}
 #kb-list dt{justify-self:start}
 #kb-list dd{margin:0;font-size:13px;color:var(--muted)}
 #kb-list kbd{display:inline-block;min-width:22px;text-align:center;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11.5px;
  color:var(--ink);background:var(--panel-2);border:1px solid var(--line);border-bottom-width:2px;border-radius:6px;padding:2px 6px}
 .sw-hint{margin:9px 2px 2px;font-size:11.5px;color:var(--faint)}
 /* ── bundle-count badge (hub only) ── */
 #btn-switch{position:relative}
 .swcount{position:absolute;top:-6px;right:-6px;min-width:16px;height:16px;padding:0 4px;border-radius:9px;background:var(--accent);
  color:#fff;font-size:10.5px;font-weight:700;display:grid;place-items:center;line-height:1}
 .swcount[hidden]{display:none}
 @keyframes swping{0%{box-shadow:0 0 0 0 rgba(226,30,30,.5)}100%{box-shadow:0 0 0 9px rgba(226,30,30,0)}}
 .swcount:not([hidden]){animation:swping 1.6s ease-out .6s 4}
 /* ── mobile nav (hamburger + drawer) and the one-time desktop note ── */
 #btn-menu{display:none;position:relative;flex:none}
 #btn-menu .menudot{position:absolute;top:-3px;right:-3px;width:9px;height:9px;border-radius:50%;background:var(--accent)}
 #btn-menu .menudot[hidden]{display:none}
 #nav-bk{position:fixed;inset:0;z-index:74;background:rgba(0,0,0,.35)}
 #nav-bk[hidden]{display:none}
 /* the second beat: where the rail is folded behind ☰, a reader who has just
    left the graph cannot see where the other views went. It sits *under the
    button it is about*, with a caret pointing at it — a bottom sheet naming a
    top-left control asks the reader to do the mapping. Lighter than the first
    note in every way, because it is a nudge and not a decision. */
 #hello2{position:fixed;top:56px;left:10px;z-index:73;max-width:250px;
  background:var(--panel);border:1px solid var(--line);border-radius:12px;box-shadow:var(--shadow);
  padding:12px 13px 11px;color:var(--ink)}
 #hello2[hidden]{display:none}
 @media (min-width:769px){ #hello2{display:none} }
 #hello2::before{content:"";position:absolute;top:-6px;left:16px;width:10px;height:10px;
  background:var(--panel);border-left:1px solid var(--line);border-top:1px solid var(--line);transform:rotate(45deg)}
 #hello2 .hello-dots{margin-bottom:9px}
 #hello2 .hello2-h{margin:0 0 5px;font-size:15px;font-weight:650;line-height:1.3}
 #hello2 .hello2-b{margin:0 0 11px;font-size:13px;line-height:1.45;color:var(--muted)}
 #hello2 #hello2-x{min-height:40px;font-size:14px}
 /* the first-visit note. One card at the bottom of the graph, stacked so each
    part does one job: the question, then the action, then the gestures. It was
    a single 13px paragraph with the action buried mid-sentence, which is the
    one layout that fails hardest on the screen it matters most on. */
 #hello{position:fixed;left:12px;right:12px;bottom:12px;z-index:72;
  background:var(--panel);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow);
  padding:18px 18px 16px;color:var(--ink)}
 @media (min-width:769px){ #hello{left:50%;right:auto;transform:translateX(-50%);width:380px} }
 #hello[hidden]{display:none}
 /* a *sibling* combinator, not a descendant one: the note lives outside #app,
    next to the other fixed overlays, so `#app … #hello` matches nothing */
 #app:not([data-view=graph]) ~ #hello{display:none}
 /* the page's own vocabulary: the hint says "any dot", and these are what it
    means — the graph's real node colours, at something like their real size */
 .hello-dots{display:flex;gap:5px;margin-bottom:11px}
 .hello-dots i{width:9px;height:9px;border-radius:50%}
 .hello-dots i:nth-child(1){background:#6E56CF}
 .hello-dots i:nth-child(2){background:#D97757}
 .hello-dots i:nth-child(3){background:#22C55E}
 #hello .hello-h{margin:0 0 13px;font-size:17px;font-weight:650;letter-spacing:-.01em;line-height:1.25}
 /* One rule dresses both notes' buttons — they are the same guide speaking, and
    a shared selector is what keeps them from drifting apart later. Ink-on-bg
    rather than the accent: it is the only pairing that clears 4.5:1 in both
    themes, and it leaves the dots as the one piece of colour in either card. */
 #hello #hello-go,#hello2 #hello2-x{display:block;width:100%;min-height:46px;border:0;border-radius:11px;
  background:var(--ink);color:var(--bg);font-family:inherit;font-size:15px;font-weight:600;cursor:pointer}
 #hello #hello-go:hover,#hello2 #hello2-x:hover{opacity:.88}
 #hello .hello-hint{margin:13px 0 0;font-size:13.5px;line-height:1.5;color:var(--muted)}
 #hello #hello-x{position:absolute;top:11px;right:11px;width:34px;height:34px;font-size:13px}
 /* Two independent questions, so two independent gates — width answers neither
    on its own. What the reader *does* follows the pointer: a touch tablet in
    landscape is wider than 768px and still taps, a narrow desktop window is
    narrower and still clicks. What the reader can *reach* follows the width:
    ☰ exists only once the rail collapses, so promising it anywhere else is a
    lie. A pointer-less environment matches nothing and keeps the click wording,
    which is the safe default. */
 #hello .hello-touch{display:none}
 @media (pointer:coarse){ #hello .hello-touch{display:inline} #hello .hello-point{display:none} }
 #hello .hello-menu{display:none}
 @media (max-width:768px){ #hello .hello-menu{display:inline} }
 /* a landscape phone has width to spare and no height at all, where the stacked
    card takes half the screen — same words, tighter setting */
 @media (max-height:480px){
  #hello{padding:13px 15px 12px;border-radius:14px}
  #hello .hello-dots{margin-bottom:8px}
  #hello .hello-h{font-size:15.5px;margin-bottom:10px}
  #hello #hello-go{min-height:42px;font-size:14.5px}
  #hello .hello-hint{margin-top:9px;font-size:12.5px}
 }
 /* and once it is short *and* wide, the stack itself is the problem: the
    question and the action sit on one row and spend the width instead of the
    height. Scoped to ≥769px so it stays inside the centred regime above —
    below that the card is edge-to-edge with no transform to conflict with. */
 @media (max-height:480px) and (min-width:769px){
  #hello{display:grid;grid-template-columns:1fr auto;column-gap:18px;align-items:center;
   width:min(640px,calc(100vw - 24px))}
  #hello .hello-dots{grid-column:1/-1}
  #hello .hello-h{grid-column:1;grid-row:2;margin:0}
  #hello #hello-go{grid-column:2;grid-row:2;width:auto;padding:0 22px}
  #hello .hello-hint{grid-column:1/-1;margin-top:10px}
 }
 @media (prefers-reduced-motion:no-preference){
  #hello:not([hidden]){animation:hello-in .22s ease-out both}
  @keyframes hello-in{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  @media (min-width:769px){
   #hello:not([hidden]){animation-name:hello-in-c}
   @keyframes hello-in-c{from{opacity:0;transform:translate(-50%,10px)}to{opacity:1;transform:translate(-50%,0)}}
  }
 }

 /* ── catalog ── */
 .pad{padding:22px 24px;overflow:auto;flex:1}
 .cat-types{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px}
 .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
 .card{background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:15px 16px 13px;cursor:pointer;
  display:flex;flex-direction:column;gap:9px;box-shadow:var(--shadow);transition:transform .16s cubic-bezier(.22,1,.36,1),border-color .16s}
 .card:hover{transform:translateY(-3px);border-color:var(--accent)}
 .card:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
 .card .r1{display:flex;align-items:center;gap:8px}
 .card .area{margin-left:auto;font-size:11.5px;color:var(--faint);font-family:ui-monospace,monospace}
 .card h3{font-size:15.5px;font-weight:600;letter-spacing:-.01em;line-height:1.28}
 .card .cd{font-size:13px;color:var(--muted);margin:0;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
 .card .cm{display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-top:auto;padding-top:9px;border-top:1px solid var(--line-2)}
 .card .mini{font-size:11.5px;color:var(--faint);display:inline-flex;gap:4px;align-items:center}
 .card .mini.links{color:var(--accent-ink);margin-left:auto}
 .none{grid-column:1/-1;text-align:center;color:var(--faint);padding:48px;border:1px dashed var(--line);border-radius:12px}

 /* ── files ── */
 .files-grid{display:grid;grid-template-columns:var(--ftree-w,320px) 1fr;height:100%;min-height:0}
 /* min-width:0 — the file rows' nowrap descriptions would otherwise set the
    pane's min-content width and blow the 1fr column past a phone viewport
    (the fixed desktop column never hits this) */
 .ftree{position:relative;border-right:1px solid var(--line);display:flex;flex-direction:column;min-height:0;min-width:0;background:var(--panel)}
 /* drag handle on the file list's right edge (double-click resets the width) */
 #ftree-resizer{position:absolute;right:-4px;top:0;bottom:0;width:7px;cursor:col-resize;z-index:4;touch-action:none}
 #ftree-resizer::after{content:"";position:absolute;right:3px;top:0;bottom:0;width:2px;background:var(--accent);opacity:0;transition:opacity .15s}
 #ftree-resizer:hover::after,#ftree-resizer.dragging::after{opacity:.7}
 .ftree-list{overflow:auto;flex:1;padding:8px}
 /* --d is the row's depth in the tree, set inline by the renderer; the Indexes
    tab sets none and falls back to 0, which is the flat list it wants. */
 .ffolder{display:flex;align-items:center;gap:6px;width:100%;text-align:left;border:0;background:none;cursor:pointer;font-family:inherit;
  font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);font-weight:600;
  padding:12px 8px 5px calc(8px + var(--d,0)*13px)}
 .ffolder:hover{color:var(--muted)}
 /* the root row carries the bundle's name rather than a path segment, so it is
    set as a name: no uppercasing, and truncated instead of wrapping */
 .ffolder.root{text-transform:none;letter-spacing:0;font-size:12px;color:var(--muted)}
 .ffolder.root span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
 .ffolder .chev{width:11px;height:11px;flex:none;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;transition:transform .15s}
 .ffolder.closed .chev{transform:rotate(-90deg)}
 .file.res .fn{color:var(--muted)}
 .file .fn .ricon{width:12px;height:12px;flex:none;stroke:var(--faint);fill:none;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round}
 .ftabs{display:flex;gap:6px;padding:9px 10px;border-bottom:1px solid var(--line);flex:none;align-items:center}
 .ftree-name{font-size:12.5px;font-weight:600;color:var(--ink);padding-left:2px}
 /* the filter that replaced the Indexes tab: pressed, it narrows the same tree
    to the authored layer instead of swapping in a second, flat one */
 #ftree-ixonly{height:28px;gap:5px;font-size:12px;color:var(--muted)}
 #ftree-ixonly svg{width:13px;height:13px}
 #ftree-ixonly[aria-pressed=true]{background:var(--accent-soft);color:var(--accent-ink);border-color:transparent}
 /* mobile-only: collapses the stacked file list down to this tab bar */
 #ftree-min{display:none;width:28px;height:28px;flex:none;margin-left:auto}
 #ftree-min svg{transition:transform .15s}
 .files-grid.tree-min #ftree-min svg{transform:rotate(180deg)}
 #ftree-foldall{width:28px;height:28px;flex:none}
 #ftree-foldall svg{transition:transform .15s}
 #ftree-foldall.all-closed svg{transform:rotate(180deg)}
 .file .fn .badge-res{margin-left:auto;flex:none;font-size:9.5px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;
  color:var(--faint);background:var(--line-2);border:1px solid var(--line);border-radius:999px;padding:1px 7px}
 /* The name needs an element of its own: as a bare text node it was an
    anonymous flex item, whose automatic minimum size is the full width of the
    text — so a long path refused to shrink and drove the badge past the right
    edge instead. overflow:hidden takes that minimum to zero, which is what lets
    the name give way and the badge stay put. */
 .file .fn .rn{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .file{display:block;width:100%;text-align:left;border:0;background:none;border-radius:8px;cursor:pointer;font-family:inherit;color:var(--ink);
  padding:7px 9px 7px calc(8px + var(--d,0)*13px)}
 .file:hover{background:var(--panel-2)} .file.sel{background:var(--accent-soft)}
 .file .fn{font-size:13px;font-weight:500;display:flex;align-items:center;gap:7px}
 .file .fn .dot{width:7px;height:7px;border-radius:50%;flex:none}
 .file .fd{font-size:11.5px;color:var(--faint);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .fpreview{min-width:0;overflow:auto;display:flex;flex-direction:column}
 .fp-head{display:flex;align-items:center;gap:10px;padding:14px 22px;border-bottom:1px solid var(--line);flex:none}
 /* `display:flex` outranks the UA sheet's `[hidden]{display:none}`, so the head
    stayed on screen with nothing in it — an empty badge and a graph button
    pointing nowhere — every time the reader had no file open. */
 .fp-head[hidden]{display:none}
 .fp-head .title{margin:0;font-size:16px}
 .fp-body{padding:20px 28px;overflow:auto;flex:1}
 .fp-body .body{border-top:0;padding-top:0;margin-top:0}

 /* ── tags ── */
 .cloud{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;align-items:center}
 .tcloud{border:1px solid color-mix(in srgb,var(--accent) var(--heat,0%),var(--line));background:color-mix(in srgb,var(--accent) var(--heat,0%),var(--panel));border-radius:999px;padding:6px 13px;cursor:pointer;color:var(--ink);font-family:inherit;font-size:13px;transition:.14s}
 .tcloud:hover{border-color:var(--accent);color:var(--accent-ink)} .tcloud.on{background:var(--accent);border-color:var(--accent);color:#fff}
 .tcloud b{color:var(--faint);font-weight:600;font-variant-numeric:tabular-nums;font-size:.8em;margin-left:5px} .tcloud.on b{color:rgba(255,255,255,.75)}
 .tlist{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:9px}
 .titem{display:flex;align-items:center;gap:9px;padding:9px 12px;border:1px solid var(--line);border-radius:10px;background:var(--panel);cursor:pointer;transition:.14s;font-family:inherit;text-align:left;color:var(--ink)}
 .titem:hover{border-color:var(--accent);transform:translateY(-2px)}
 .titem .dot{width:9px;height:9px;border-radius:50%;flex:none} .titem .tt{font-size:13.5px;font-weight:500}
 .titem .ty{font-size:11px;color:var(--faint);margin-left:auto}

 /* ── stats ── */
 .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:13px;margin-bottom:26px}
 .stat{background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:17px 18px;box-shadow:var(--shadow)}
 .stat .n{font-size:30px;font-weight:700;letter-spacing:-.02em;line-height:1;font-variant-numeric:tabular-nums}
 .stat .l{font-size:11.5px;color:var(--muted);margin-top:7px;text-transform:uppercase;letter-spacing:.05em;font-weight:500}
 .stat .n .u{color:var(--accent)}
 .bars{display:flex;flex-direction:column;gap:9px;max-width:640px}
 .bar{display:grid;grid-template-columns:150px 1fr 40px;align-items:center;gap:12px}
 .bar .bl{font-size:12.5px;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
 .bar .bt{height:9px;border-radius:5px;background:var(--line-2);overflow:hidden}
 .bar .bf{height:100%;border-radius:5px;transform-origin:left;transition:transform .5s cubic-bezier(.22,1,.36,1)}
 .bar .bv{font-size:12px;color:var(--faint);text-align:right;font-variant-numeric:tabular-nums}
 .bar.clickable{cursor:pointer;border-radius:8px;padding:3px 7px;margin:0 -7px;transition:background .13s}
 .bar.clickable:hover{background:var(--panel-2)} .bar.clickable:hover .bl{color:var(--accent-ink)}
 .bar.clickable:focus-visible{outline:2px solid var(--accent);outline-offset:1px}
 .two{display:grid;grid-template-columns:1fr 1fr;gap:30px} @media(max-width:820px){.two{grid-template-columns:1fr}}

 /* ── type autocomplete (graph filters + catalog) ── */
 .combo{position:relative;flex:none;width:170px}
 .combo input{width:100%;padding-right:26px}
 .combo .clear{position:absolute;right:6px;top:50%;transform:translateY(-50%);border:0;background:none;color:var(--muted);cursor:pointer;width:20px;height:20px;border-radius:6px;display:none;place-items:center;padding:0}
 .combo .clear svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round}
 .combo.has .clear{display:grid}
 .listbox{position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:60;margin:0;padding:6px;list-style:none;background:var(--panel);
  border:1px solid var(--line);border-radius:11px;box-shadow:var(--shadow);max-height:320px;overflow:auto;animation:pop .13s cubic-bezier(.22,1,.36,1)}
 .listbox[hidden]{display:none}
 .opt{display:flex;align-items:center;gap:9px;padding:7px 9px;border-radius:7px;font-size:13px;color:var(--ink);cursor:pointer;white-space:nowrap}
 .opt .sw{width:9px;height:9px;border-radius:50%;flex:none} .opt .c{margin-left:auto;color:var(--faint);font-size:12px}
 .opt:hover,.opt.active{background:var(--line-2)} .opt.sel{color:var(--accent-ink);font-weight:600}
 @keyframes pop{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:none}}

 /* ── the synthesized-map listing (inspector + files preview) ── */
 .ix-listing{margin:10px 0 0;padding:0;list-style:none}
 .ix-listing li{padding:3px 0;font-size:13.5px}
 .ix-listing a{color:var(--accent-ink);text-decoration:none;cursor:pointer}
 .ix-listing a:hover{text-decoration:underline}
 .ix-listing .d{color:var(--muted)}

 /* ── concept preview (touch) ────────────────────────────────────────────────
    Deliberately not a third "sheet": the ⚙ tools sheet and the ? sheet already
    own that word, and a third would make every `grep -n sheet` on this file
    ambiguous. This is the preview card — what a tap on a dot opens on a touch
    screen, in place of the inspector.

    In place of it because at this width the inspector *is* the viewport:
    `grid-template-columns:0 1fr` below measures #stage at width 0, so tapping a
    dot did not cover the graph, it deleted it, and exploring a phone became
    open → read → close → tap the next dot. The card puts the concept's head at
    the bottom edge and leaves the graph every pixel it had, live above it.

    The element is the whole band from under the topbar to the bottom edge, so a
    snap point is only a translateY: visible height H ⇒ translateY(FULL - H).
    Hidden is translateY(100%); display:none off the touch branch keeps the
    desktop DOM inert — no layout, no width, nothing to widen the document,
    which is the lesson the Bundles panel above already paid for. ── */
 #preview{position:fixed;left:0;right:0;top:var(--pv-top,56px);bottom:0;z-index:70;display:none;flex-direction:column;
  background:var(--panel);border-top:1px solid var(--line);border-radius:16px 16px 0 0;
  box-shadow:0 -10px 34px rgba(0,0,0,.30),0 -1px 0 var(--line);
  /* No transition on transform, and that is the feature. The card used to rise
     over 0.26s, so every one of the dozens of taps that exploring a graph takes
     cost the same wait — and a miss on bare canvas dismissed it, which meant the
     next dot replayed the entrance from scratch. Dragging still moves the card
     directly; that was never a transition, so it survived. Nothing else may
     animate here: mobile-preview.spec.js counts the distinct transform values
     the element wears while it is on screen, and the contract is exactly one. */
  transform:translateY(100%);overscroll-behavior:contain}
 /* the grip and the head are the drag surface, so the browser must not claim
    the gesture for a scroll — but only here, or the card's own body stops
    scrolling at `full` */
 #pv-grip{flex:none;padding:9px 0 4px;display:flex;justify-content:center;touch-action:none;cursor:grab}
 #pv-grip:active{cursor:grabbing}
 #pv-grip .pill{display:block;width:40px;height:4px;border-radius:3px;background:var(--line-2);border:1px solid var(--line)}
 #pv-grip:focus-visible{outline:2px solid var(--accent);outline-offset:-3px;border-radius:10px}
 #pv-head{flex:none;position:relative;touch-action:none;padding:2px 16px 12px;border-bottom:1px solid var(--line)}
 /* a tablet is not a stretched phone: the column stops at a readable measure and
    centres, while the card still spans the screen */
 #pv-head>.col,#pv-body>.col{max-width:720px;margin:0 auto;width:100%}
 #pv-x{position:absolute;top:0;right:10px;width:30px;height:30px;z-index:2}
 #preview .pv-title{font-size:17px;font-weight:600;margin:.45em 0 0;line-height:1.32;letter-spacing:-.01em;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 #preview .pv-desc{color:var(--muted);margin:7px 0 0;font-size:13.5px;line-height:1.5;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 #preview[data-snap=half] .pv-desc,#preview[data-snap=full] .pv-desc{-webkit-line-clamp:4}
 #preview .pv-meta{margin:9px 0 0;font-size:11.5px;color:var(--faint);font-variant-numeric:tabular-nums}
 #pv-head .type{max-width:calc(100% - 38px)}
 #pv-body{flex:1;min-height:0;overflow:auto;-webkit-overflow-scrolling:touch;padding:14px 16px 30px}
 #pv-body .rel:first-child{margin-top:0}
 #pv-body .body{font-size:14.5px}
 /* the canvas hint sits exactly where the card lands */
 #app.preview-up .ghint{display:none}

 /* ── compact chrome for ≤768px (phones and portrait tablets): the rail becomes
    a drawer behind ☰ and every topbar tool collapses into the ⚙ sheet. Wider
    viewports — a rotated tablet included — fall back to the desktop layout;
    the media query re-evaluates live, so rotation flips strategy on its own ── */
 @media (max-width:768px){
  #app{grid-template-columns:1fr}
  #main{grid-column:1}
  #rail{position:fixed;left:0;top:0;bottom:0;z-index:75;width:76px;transform:translateX(-100%);transition:transform .18s ease}
  #app.nav-open #rail{transform:none;box-shadow:0 0 40px rgba(0,0,0,.4)}
  #btn-menu{display:inline-grid}
  #topbar{gap:8px;padding:10px 10px;position:relative;flex-wrap:nowrap}
  .ident{min-width:0;overflow:hidden;text-overflow:ellipsis;flex:1 1 auto}
  .ident .muted{display:none}
  /* the bar keeps only ☰ · title · ⚙ — search and every control move into the
     ⚙ sheet, on every view (stats has nothing to show, so no ⚙ there) */
  #btn-controls{display:inline-grid}
  #app[data-view=stats] #btn-controls{display:none}
  #bar-tools{display:none}
  #app.controls-open #bar-tools{display:flex;position:absolute;top:100%;left:0;right:0;z-index:55;
   flex-direction:column;align-items:stretch;gap:9px;padding:10px 12px;
   background:var(--panel);border-bottom:1px solid var(--line);box-shadow:var(--shadow)}
  #bar-tools .search{min-width:0;max-width:none;flex:1 1 auto} /* search spans the full sheet width */
  #app.controls-open #graph-controls,#app.controls-open #file-controls{flex-wrap:wrap}
  #app.controls-open #file-controls .combo{flex:1 1 44%;width:auto;min-width:130px}
  /* Wrapping by whatever happened to fit left one icon orphaned on a line of its
     own. The two controls carrying words take a column each, so the first line
     is two even halves; the icon buttons then get a line to themselves and
     spread across it. */
  #app.controls-open #graph-controls{gap:8px}
  #app.controls-open #graph-controls>#btn-filters,
  #app.controls-open #graph-controls>.selwrap{flex:1 1 calc(50% - 4px);min-width:0}
  /* the select has to grow with its wrapper. Stretching only the wrapper left
     the control at its natural width with the chevron pinned to the wrapper's
     far edge — a chevron floating over dead space, and every click on it lost. */
  #app.controls-open #graph-controls>.selwrap>#layout{width:100%}
  /* the graph inspector takes the whole viewport — the ✕ closes it; widening,
     drag-resizing, and the topbar panel toggle have no job at this size
     (grid-template beats the resizer's inline --side-w) */
  .graph-body[data-side=default],.graph-body[data-side=wide]{grid-template-columns:0 1fr}
  #side{border-left:0}
  #side-widen,#side-resizer,#btn-panel{display:none}
  /* the files view stacks: list on top, reader below — side-by-side panes
     don't survive a phone width */
  .files-grid{grid-template-columns:1fr;grid-template-rows:minmax(0,42%) minmax(0,1fr)}
  .ftree{border-right:0;border-bottom:1px solid var(--line)}
  #ftree-resizer{display:none}
  .fp-body{padding:16px 14px}
  /* "Open in graph" shrinks to its icon — the label steals a third of the
     reader header on a phone (tooltip and aria-label carry the name) */
  #fp-graph .fpg-lbl{display:none}
  #fp-graph{width:34px;padding:0;flex:none}
  /* the list collapses to its tab bar so the reader gets the screen — picking
     a file collapses it, picking a tab brings it back */
  #ftree-min{display:inline-grid}
  .files-grid.tree-min{grid-template-rows:auto minmax(0,1fr)}
  .files-grid.tree-min .ftree-list{display:none}
 }
 /* The card's branch is wider than the chrome's above. A portrait tablet keeps
    the rail and the desktop topbar — it has the room — but 0-width-stage is its
    bug too, and a bottom card is the right gesture on any touch screen held
    upright. Landscape at the same size matches neither and keeps the inspector.
    Written twice, here and as MOBILE_MQ in the JS, because neither language can
    read the other: they are one decision, so keep them identical. */
 @media (max-width:768px),(max-width:1024px) and (orientation:portrait){
  #preview.up{display:flex}
  /* the inspector's controls have no job on this branch — the panel they toggle
     can only ever show its "Select a concept…" placeholder, because show() is
     what fills it and show() never runs here */
  #btn-panel,#side-widen,#side-resizer{display:none}
 }
 /* on a portrait tablet the rail is still on screen (it only folds at 768px), so
    the card starts where the rail ends — one that buried Stats under itself
    would be the takeover again, just shorter */
 @media (min-width:769px) and (max-width:1024px) and (orientation:portrait){
  #preview{left:76px;border-top-left-radius:16px}
 }
 /* ── tablet and up: the panes stay side-by-side, but the same chevron folds
    the whole list column into a slim strip so the reader takes the width ── */
 @media (min-width:769px){
  #ftree-min{display:inline-grid}
  #ftree-min svg{transform:rotate(90deg)}
  .files-grid.tree-min #ftree-min svg{transform:rotate(-90deg)}
  .files-grid.tree-min{grid-template-columns:auto 1fr}
  .files-grid.tree-min .ftree-list,.files-grid.tree-min .ftabs,.files-grid.tree-min #ftree-resizer{display:none}
 }
 @media (prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style></head>
<body>
<div id="app" data-view="graph">
 <nav id="rail" aria-label="Views">
  <%# Behind a hub the mark is the way back to every bundle — the missing-navbar
      fix in miniature, and "../" reaches it under any mount because every page
      lives at <prefix>/b/<slug>/. Standalone and static have nowhere to go, so
      there it stays the plain identity badge it has always been. %>
  <%= rail_brand_open %><%= escaped_name %> — <%= @graph.nodes.length %> concepts · <%= @graph.edges.length %> links">
   <svg viewBox="0 0 100 100"><rect width="100" height="100" rx="24" fill="#1a1a1a"/><polygon points="38,44 62,44 50,82" fill="#7a0a1e"/><polygon points="18,44 38,44 50,82" fill="#a8112c"/><polygon points="62,44 82,44 50,82" fill="#a8112c"/><polygon points="35,28 18,44 38,44" fill="#dc1e3c"/><polygon points="65,28 82,44 62,44" fill="#dc1e3c"/><polygon points="35,28 65,28 62,44 38,44" fill="#f43f5e"/><polygon points="36,29 49,29 42,42" fill="#fff" opacity=".38"/><polygon points="35,28 65,28 82,44 50,82 18,44" fill="none" stroke="#ff6b7f" stroke-width="2" stroke-linejoin="round"/></svg>
  <%= rail_brand_close %>
  <button class="rail-item active" data-view="graph"><span class="ri-ico"><svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="2.4"/><circle cx="18" cy="9" r="2.4"/><circle cx="9" cy="18" r="2.4"/><path d="M7.7 7.3 15.9 8.6M7.5 16 8.2 8.3M10.9 16.4 16.3 10.5"/></svg></span><span class="ri-lbl">Graph</span></button>
  <button class="rail-item" data-view="index"><span class="ri-ico"><svg viewBox="0 0 24 24"><path d="M4 5h16M4 9.6h10.5M4 14.2h16M4 18.8h7.5"/></svg></span><span class="ri-lbl">Index</span></button>
  <button class="rail-item" data-view="files"><span class="ri-ico"><svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h3.5l2 2H19a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg></span><span class="ri-lbl">Files</span></button>
  <button class="rail-item" data-view="catalog"><span class="ri-ico"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="7.5" height="7.5" rx="1.6"/><rect x="13.5" y="4" width="7.5" height="7.5" rx="1.6"/><rect x="3" y="14.5" width="7.5" height="5.5" rx="1.6"/><rect x="13.5" y="14.5" width="7.5" height="5.5" rx="1.6"/></svg></span><span class="ri-lbl">Catalog</span></button>
  <button class="rail-item" data-view="tags"><span class="ri-ico"><svg viewBox="0 0 24 24"><path d="M4 4.5h6.8L20 13.7l-6.3 6.3L4.5 10.8V4.5Z"/><circle cx="8.4" cy="8.4" r="1.4" fill="currentColor" stroke="none"/></svg></span><span class="ri-lbl">Tags</span></button>
  <button class="rail-item" data-view="stats"><span class="ri-ico"><svg viewBox="0 0 24 24"><path d="M5 20V11M12 20V4M19 20v-6"/></svg></span><span class="ri-lbl">Stats</span></button>
  <div class="rail-sp"></div>
  <div class="rail-tools">
   <button class="btn" id="btn-switch" type="button" hidden aria-label="Switch bundle (⌘K)" title="Switch bundle (⌘K)">
    <svg viewBox="0 0 24 24"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3Z"/></svg>
    <span class="swcount" id="sw-count" hidden>0</span></button>
   <%# Only a registry-backed hub has anything here to manage; the JS reveals it
       off MANAGE_ROOT, the same way the switcher reveals itself off HUB_PATH. %>
   <button class="btn" id="btn-ws" type="button" hidden aria-label="Bundles (registry)" title="Bundles (registry)" aria-expanded="false">
