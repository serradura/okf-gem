  const body='<div class="ws-row-main"><div class="ws-t">'+title+pills+'</div>'+
   '<div class="ws-meta"><span class="ws-slug">@'+esc(b.slug)+'</span>'+count+
   '<span class="ws-health '+esc(b.health)+'">'+esc(b.word)+'</span></div>'+
