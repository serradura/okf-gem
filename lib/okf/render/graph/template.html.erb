<script>
/* ═══ JS sections, in file order ════════════════════════════════════════════
   Same `── name ──` banners as the CSS above; same grep prints them with live
   line numbers.

     payload + derived indexes     Cytoscape (style, instance)
     Mermaid (lazy)                fullscreen diagram viewer
     inspector                     drag-resize splitters
     graph filters                 layout
     cluster by directory          file-tree mode
     the authored layer            fit to screen
     view switching                full-text search
     catalog                       files
     tags                          stats
     theme / fullscreen            §6 map payload · §7 log payload
     command palette               the search bridge
     concept preview (touch)       mobile drawer + sheet
     keyboard                      deep links · first visit

   ── What actually couples these ──────────────────────────────────────────
   The sections are tidy lexically and entangled at runtime, which is why a
   change in one breaks another. Three seams carry almost all of it:

   1. `applyGraphFilter()` is the shared sink. The search box, the three chip
      groups in the slide-over, the inspector's focus chips and cluster mode
      all funnel into it, and it reads `q.graph`, `activeTypes`, `activeTags`,
      `activeDirs` and `ftMatch()` together. Touching any one caller can
      change what the other four produce.
   2. `setView()` reaches into nearly every section — it toggles the tool
      groups, seeds a view on first entry via `inited`, and has to
      `cy.resize()` on the way back to the graph, because Cytoscape measures a
      hidden container as 0×0 and returns collapsed without it.
   3. The lazy caches — `CATALOG`, `INDEX`, `LOGS`, `ftIndex` — are each
      filled by one section and read by three or four. A stale one is
      invisible until an unrelated view renders wrong.

   The mode flags (`clustered` + `clusterDepth`, `treeMode`, `ixNodes`,
   `ixOnly`, `view`) are
   read across boundaries too: each rebuilds the graph's elements and must
   undo itself exactly, or its nodes leak into the plain view.

   All of the above is pinned by test/browser/ — `bundle exec rake
   test:browser`. Run it before and after editing this file; it drives the
   real page in Chromium and fails on any error the page throws.
   ═════════════════════════════════════════════════════════════════════════ */
const NODES=<%= nodes_json %>, EDGES=<%= edges_json %>, TYPES=<%= types_json %>, TAGS=<%= tags_json %>;
const NODE_ENDPOINT=<%= @node_endpoint.to_json %>, META_ENDPOINT=<%= @meta_endpoint.to_json %>;
const BUNDLE=<%= name_json %>;
const CATALOG_ENDPOINT="catalog",INDEX_ENDPOINT="index",LOG_ENDPOINT="log";
/* The hub's bundle switcher (⌘/Ctrl-K). SIBLINGS is empty for a standalone
   server and for `okf render`, so a single bundle or a static file offers none. */
const SIBLINGS=<%= siblings_json %>, SELF_SLUG=<%= self_slug_json %>, HUB_PATH=<%= hub_path_json %>;
/* The hub's cross-bundle search, mount-relative — null for a standalone server
   and for `okf render`, where there is no set of bundles to search. */
const SEARCH_ENDPOINT=<%= search_endpoint_json %>;
/* The hub root, mount-relative — where the Bundles panel reads /bundles and
   posts /registry/<verb>. Null for a standalone server and for `okf render`,
   and that null is the gate: neither has a registry behind it, so neither ever
   shows the ⚙. MANAGE_TOKEN is null wherever a write would be refused anyway
   (a read-only bind, an ephemeral set), so the page holds no credential it
   cannot use — and the panel reads that null to explain itself. */
const MANAGE_ROOT=<%= manage_root_json %>, MANAGE_TOKEN=<%= manage_token_json %>;
/* null when served live (`okf server`) — the getters below fetch the endpoints
   above. `okf render` injects a payload {catalog,index,logs,bodies}, and every
   getter resolves from it instead (the /node/meta fragment derived from the
   catalog), so one file needs no server and the endpoint consts above go inert. */
const EMBED=<%= embed_json %>;
/* Full-text search state (MiniSearch, lazy — built on first search). One ranked
   index behind the search box for the graph, catalog and files views. It indexes
   title/id/type/tags/description in every mode, plus each concept body wherever
   the page already holds it: `okf render` bakes every body in, so a static file
   searches bodies offline; the live server keeps bodies lazy, so its index stays
   metadata-only until a backend body index arrives. Same 7.2.0 build and config
   as the Ruby port, so a Ruby-built index and this one rank identically. */
const FT_FIELDS=['title','id','type','tags','description'].concat(EMBED?['body']:[]);
let _MiniSearch=null,ftIndex=null,ftBuilding=null;
const descOf={};
const MIN=<%= OKF::Render::Graph::MIN_SIZE %>, MAX=<%= OKF::Render::Graph::MAX_SIZE %>;
const PALETTE=["#6E56CF","#D97757","#22C55E","#3B82F6","#EAB308","#EC4899","#14B8A6","#F97316","#A855F7","#0EA5E9","#84CC16","#EF4444","#64748B"];
const root=document.documentElement;
const byId=Object.fromEntries(NODES.map(n=>[n.id,n]));
const outL={}, inL={};
NODES.forEach(n=>{outL[n.id]=[];inL[n.id]=[];});
EDGES.forEach(e=>{outL[e.source].push(e.target);inL[e.target].push(e.source);});
const typeOf={};Object.entries(TYPES).forEach(([t,ids])=>ids.forEach(id=>typeOf[id]=t));
const tagsOf={};NODES.forEach(n=>tagsOf[n.id]=[]);Object.entries(TAGS).forEach(([t,ids])=>ids.forEach(id=>{(tagsOf[id]=tagsOf[id]||[]).push(t);}));
const types=Object.keys(TYPES).sort();
const color=Object.fromEntries(types.map((t,i)=>[t,PALETTE[i%PALETTE.length]]));
const deg=id=>(outL[id]||[]).length+(inL[id]||[]).length;
const szOf=id=>Math.max(MIN,Math.min(MAX,MIN+deg(id)*4));
// Quotes included, because this escape feeds attributes as well as text:
// `href="${esc(...)}"` breaks out of its own quoting the moment one survives.
// The Ruby half of the page escapes the same set (Rack::Utils.escape_html), and
// an escape whose safety depends on where the caller happens to interpolate it
// is the shape of the XSS this page's trust boundary exists to refuse.
const esc=s=>(s==null?'':String(s)).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const cvar=n=>getComputedStyle(root).getPropertyValue(n).trim();
const isDark=()=>root.getAttribute('data-theme')==='dark';
const reduce=()=>matchMedia('(prefers-reduced-motion:reduce)').matches;
/* A concept's directory — the whole path, "." at the root — mirroring the
   `dir` every catalog row carries. This used to be `areaOf`, the *first path
   segment* only: a word the OKF spec never uses, and a projection that made
   nested clustering impossible because everything below level one was already
   thrown away before the boxes were drawn. */
const dirOf=id=>{const i=id.lastIndexOf('/');return i<0?'.':id.slice(0,i);};
const dirDepth=d=>d==='.'?0:d.split('/').length;
const dirTrunc=(d,n)=>d==='.'?'.':d.split('/').slice(0,n).join('/');
const dirParent=d=>{const i=d.lastIndexOf('/');return i<0?null:d.slice(0,i);};
/* The one rule `okf --dir` uses, verbatim: a directory names itself and
   everything beneath it. "." needs no special case — nothing starts with "./",
   so the root selects only what lives directly in it. */
const underDir=(d,path)=>d===path||d.indexOf(path+'/')===0;
/* `.` is the data; `(root)` is what a human reads. A box caption is the last
   segment — a full path on every nested box would bury the picture in text. */
const dirLabel=d=>d==='.'?'(root)':d.split('/').pop()+'/';

/* ── Cytoscape ── */
function styleSheet(){const ink=cvar('--ink'),halo=cvar('--canvas'),edge=cvar('--edge');
 return [
  {selector:'node',style:{'background-color':'data(c)','label':'data(title)','color':ink,'font-family':'Poppins,sans-serif',
   'font-size':10,'font-weight':500,'text-wrap':'wrap','text-max-width':120,'text-valign':'bottom','text-margin-y':5,
   'text-outline-width':2.5,'text-outline-color':halo,'min-zoomed-font-size':7,'border-width':0,'width':'data(sz)','height':'data(sz)'}},
  {selector:'edge',style:{'width':1.2,'line-color':edge,'target-arrow-color':edge,'target-arrow-shape':'triangle','arrow-scale':.8,'curve-style':'bezier','opacity':.8}},
  /* A folder node and a map node are the same thing twice over — clicking
     either opens that directory's index — so they converge on one look instead
     of parting by mode: an accent square, never a concept's circle, with the
     edges into it dashed. Colour separates *kinds* here, not modes; a directory
     is not a concept and should not read as one. */
  {selector:'node.dir,node.ix',style:{'shape':'round-rectangle','background-color':cvar('--accent'),'background-opacity':.9,
   'font-size':9.5,'font-weight':700,'color':cvar('--ink')}},
  {selector:'edge.tree',style:{'width':1.1,'opacity':.7,'line-style':'dashed','target-arrow-shape':'none'}},
  /* what separates the two maps is authorship, not hue: a directory the bundle
     only implies is hollow and dashed, which is the same "not really there"
     the dashed edges say. */
  /* authorship still shows as form: a map nobody wrote is hollow and dashed */
  {selector:'node.ix-syn',style:{'background-color':cvar('--faint'),'background-opacity':.2,'color':cvar('--muted'),
   'border-width':1.5,'border-color':cvar('--faint'),'border-style':'dashed'}},
  {selector:'edge.ixe',style:{'width':1,'opacity':.5,'line-style':'dashed','line-color':cvar('--edge'),'target-arrow-shape':'none'}},
  {selector:'edge.ixe-syn',style:{'opacity':.3}},
  {selector:'edge.linkhid',style:{'display':'none'}},
  {selector:':parent',style:{'background-color':cvar('--ink'),'background-opacity':0.05,'border-width':1,'border-color':cvar('--edge'),'shape':'round-rectangle','padding':26,'label':'data(label)','color':cvar('--ink'),'font-size':13,'font-weight':600,'text-valign':'top','text-halign':'center','text-margin-y':-8,'min-zoomed-font-size':0,'text-outline-width':3,'text-outline-color':cvar('--canvas')}},
  /* ── state, last so it outranks every look above ──
     Cytoscape resolves equal-specificity selectors by array order, so a base
     rule declared after `.dim` beats it. `edge.tree` and `edge.ixe` each set
     their own opacity, which meant neither ever dimmed: a map's dashed edges
     sat at half opacity across the whole graph, and selecting one emphasised
     nothing. Dim and highlight are states, not looks — they go last. */
  {selector:'.dim',style:{'opacity':.1}},
  {selector:'.hl',style:{'border-width':3,'border-color':cvar('--accent')}}
 ];}
/* Only the floor for a graph that already fits. "Far enough out to see
   everything" is not a constant — a big bundle, especially clustered by area
   where cose spreads the compound boxes wide, needs to go well below this, and
   a floor above the fitting zoom puts the whole picture out of reach, fit
   button included. relaxZoom() lowers it to follow anything bigger. */
const MIN_ZOOM=.2;
const cy=cytoscape({container:document.getElementById('cy'),minZoom:MIN_ZOOM,maxZoom:1.6,wheelSensitivity:.2,
 elements:[...NODES.map(n=>({data:{id:n.id,title:n.title,c:color[typeOf[n.id]||'Untyped']||'#64748b',sz:szOf(n.id)}})),...EDGES.map(e=>({data:e}))],
 style:styleSheet(),layout:{name:'<%= @layout %>',animate:false,nodeRepulsion:9000,idealEdgeLength:170,padding:40,nodeOverlap:24,avoidOverlap:true,spacingFactor:1.2,nodeDimensionsIncludeLabels:true}});
function applyCyTheme(){cy.style(styleSheet());}
/* Debounced so the panel width transition (--side-w, .22s) fires cy.resize()
   once after it settles instead of on every frame — avoids canvas flicker. */
let cyResizeTimer;
new ResizeObserver(()=>{clearTimeout(cyResizeTimer);cyResizeTimer=setTimeout(()=>{cy.resize();relaxZoom();},240);}).observe(document.getElementById('cy'));
const cyEl=document.getElementById('cy');
cy.on('mouseover','node',()=>cyEl.style.cursor='pointer');
cy.on('mouseout','node',()=>cyEl.style.cursor='');

/* ── Mermaid (lazy) ── */
let _mermaid=null;
function loadMermaid(){return _mermaid||(_mermaid=new Promise((res,rej)=>{const s=document.createElement('script');
 s.src='https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';s.onload=()=>{window.mermaid.initialize({startOnLoad:false,securityLevel:'strict',theme:isDark()?'dark':'default'});res(window.mermaid);};s.onerror=rej;document.head.appendChild(s);}));}
let mermaidSeq=0;
function processMermaid(el){const blocks=[...el.querySelectorAll('code.language-mermaid')];if(!blocks.length)return;
 loadMermaid().then(m=>{const nodes=[];blocks.forEach(b=>{const pre=b.closest('pre');const d=document.createElement('div');
  d.className='mermaid';d.dataset.src=b.textContent;d.id='mmd-'+(++mermaidSeq);d.textContent=b.textContent;
  d.tabIndex=0;d.setAttribute('role','button');d.setAttribute('aria-label','Expand diagram');d.title='Expand — pan & zoom';
  pre.replaceWith(d);nodes.push(d);});
  m.run({nodes}).catch(()=>{});}).catch(()=>{});}
function rethemeMermaid(){if(!window.mermaid)return;const nodes=[...document.querySelectorAll('.mermaid')];if(!nodes.length)return;
 window.mermaid.initialize({startOnLoad:false,securityLevel:'strict',theme:isDark()?'dark':'default'});
 nodes.forEach(d=>{if(d.dataset.src){d.removeAttribute('data-processed');d.innerHTML='';d.textContent=d.dataset.src;}});
 window.mermaid.run({nodes}).catch(()=>{});}
function renderMarkdown(el,text){el.innerHTML=text?DOMPurify.sanitize(marked.parse(text)):'<span class="empty">empty body</span>';processMermaid(el);}

/* ── fullscreen diagram viewer — Panzoom (lazy, like Mermaid): click a rendered
   diagram to inspect it full screen; drag pans, wheel or pinch zooms. ── */
let _panzoom=null;
function loadPanzoom(){return _panzoom||(_panzoom=loadScript('https://cdn.jsdelivr.net/npm/@panzoom/panzoom@4/dist/panzoom.min.js').then(()=>window.Panzoom));}
const dgv=document.getElementById('dgv'),dgvStage=document.getElementById('dgv-stage'),dgvPan=document.getElementById('dgv-pan');
let dgvPz=null,dgvBack=null,dgvSeq=0;
function openDiagram(m){const src=m.dataset.src;if(!src||!m.querySelector('svg'))return;
 /* re-render from source rather than cloning the inline svg — mermaid scopes
    the styles it embeds to the svg's id, so a clone would lose its colors */
 Promise.all([ loadPanzoom(), loadMermaid() ]).then(all=>
  all[1].render('dgv-mmd-'+(++dgvSeq),src).then(out=>{
   dgvPan.innerHTML=out.svg;
   const c=dgvPan.querySelector('svg'),vb=c.viewBox&&c.viewBox.baseVal;
   const w=(vb&&vb.width)||800,h=(vb&&vb.height)||500;
   c.style.maxWidth='none';c.setAttribute('width',w);c.setAttribute('height',h);
   dgvBack=m;dgv.hidden=false;
   const fit=Math.min((innerWidth-48)/w,(innerHeight-96)/h,2);
   dgvPz=Panzoom(dgvPan,{maxScale:10,minScale:.1,startScale:fit,canvas:true,step:.2});
   document.getElementById('dgv-close').focus();
  })).catch(()=>{});}
function closeDiagram(){if(dgv.hidden)return;
 if(dgvPz){dgvPz.destroy();dgvPz=null;}
 dgv.hidden=true;dgvPan.innerHTML='';
 if(dgvBack){try{dgvBack.focus();}catch(e){}dgvBack=null;}}
dgvStage.addEventListener('wheel',e=>{if(dgvPz)dgvPz.zoomWithWheel(e);},{passive:false});
dgvStage.addEventListener('dblclick',()=>{if(dgvPz)dgvPz.reset();});
document.getElementById('dgv-in').onclick=()=>{if(dgvPz)dgvPz.zoomIn();};
document.getElementById('dgv-out').onclick=()=>{if(dgvPz)dgvPz.zoomOut();};
document.getElementById('dgv-reset').onclick=()=>{if(dgvPz)dgvPz.reset();};
document.getElementById('dgv-close').onclick=closeDiagram;
document.addEventListener('click',e=>{const m=e.target.closest&&e.target.closest('.mermaid');if(m&&!dgv.contains(e.target))openDiagram(m);});
document.addEventListener('keydown',e=>{if((e.key==='Enter'||e.key===' ')&&e.target.classList&&e.target.classList.contains('mermaid')){e.preventDefault();openDiagram(e.target);}});

/* ── inspector ── */
const gbody=document.querySelector('.graph-body'), sideBody=document.getElementById('side-body');
const btnPanel=document.getElementById('btn-panel'), sideWiden=document.getElementById('side-widen');
function setSide(s){gbody.setAttribute('data-side',s);btnPanel.setAttribute('aria-pressed',String(s!=='hidden'));
 sideWiden.setAttribute('aria-pressed',String(s==='wide'));
 sideWiden.querySelector('.wide').style.display=s==='wide'?'none':'block';
 sideWiden.querySelector('.narrow').style.display=s==='wide'?'block':'none';}
function openPanel(){if(gbody.getAttribute('data-side')!=='hidden')return false;setSide('default');return true;}
btnPanel.onclick=()=>setSide(gbody.getAttribute('data-side')==='hidden'?'default':'hidden');
document.getElementById('side-close').onclick=()=>setSide('hidden');
sideWiden.onclick=()=>setSide(gbody.getAttribute('data-side')==='wide'?'default':'wide');
/* The inspector boots hidden on every screen (data-side="hidden" in the markup,
   so the graph lays out at full width) — the first node select opens it via
   openPanel. This sync just points the header buttons at that initial state. */
setSide('hidden');
/* ── drag-resize splitters: inspector + files tree (persisted; dblclick resets) ── */
function splitter(handle,host,cssVar,key,widthAt,opts){opts=opts||{};
 /* restore clamped to the current viewport — a width dragged on a desktop
    must not swallow a phone screen */
 try{const w=parseInt(localStorage.getItem(key),10);
  if(w)host.style.setProperty(cssVar,Math.min(w,Math.round(innerWidth*.7))+'px');}catch(e){}
 handle.addEventListener('pointerdown',e=>{e.preventDefault();
  if(opts.onStart)opts.onStart();
  try{handle.setPointerCapture(e.pointerId);}catch(err){}
  handle.classList.add('dragging');host.classList.add('side-drag');
  let lastW=0,raf=false;
  /* Track the drag on window so it keeps working even where pointer capture
     is unavailable — the pointer leaves the 7px handle on the first frame. */
  const move=ev=>{lastW=Math.round(widthAt(ev));host.style.setProperty(cssVar,lastW+'px');
   if(opts.onMove&&!raf){raf=true;requestAnimationFrame(()=>{raf=false;opts.onMove();});}};
  const up=()=>{removeEventListener('pointermove',move);removeEventListener('pointerup',up);removeEventListener('pointercancel',up);
   handle.classList.remove('dragging');host.classList.remove('side-drag');
   if(opts.onEnd)opts.onEnd();
   if(lastW){try{localStorage.setItem(key,String(lastW));}catch(e){}}};
  addEventListener('pointermove',move);addEventListener('pointerup',up);addEventListener('pointercancel',up);});
 handle.addEventListener('dblclick',()=>{host.style.removeProperty(cssVar);
  try{localStorage.removeItem(key);}catch(e){}
  if(opts.onEnd)opts.onEnd();});}
const clampW=(v,lo,hi)=>Math.min(Math.max(v,lo),hi);
splitter(document.getElementById('side-resizer'),gbody,'--side-w-user','okf-side-w',
 ev=>{const r=gbody.getBoundingClientRect();return clampW(r.right-ev.clientX,280,r.width*.8);},
 {onStart:()=>{if(gbody.getAttribute('data-side')==='wide')setSide('default');},
  onMove:()=>cy.resize(),onEnd:()=>cy.resize()});
const fgrid=document.querySelector('.files-grid');
splitter(document.getElementById('ftree-resizer'),fgrid,'--ftree-w','okf-ftree-w',
 ev=>{const r=fgrid.getBoundingClientRect();return clampW(ev.clientX-r.left,220,r.width*.55);});
/* The count belongs in the eyebrow: how connected a concept is, is the first
   thing the section answers, and it answers it before the list is read. The
   title carries a title attribute because .rt truncates — the panel resizes,
   but the tooltip means a narrow one never hides a name outright. */
function relList(t,arr){if(!arr.length)return'';
 const row=id=>{const ty=typeOf[id]||'Untyped', ti=(byId[id]||{}).title||id;
  return `<a data-go="${esc(id)}" title="${esc(ti)}"><span class="dot" style="background:${color[ty]||'#64748b'}"></span><span class="rt">${esc(ti)}</span><span class="ty">${esc(ty)}</span></a>`;};
 return `<div class="rel"><h4>${t}<span class="c">${arr.length}</span></h4><div class="rellist">${arr.map(row).join('')}</div></div>`;}
/* Markdown links inside the inspector are GitHub-style relative file paths;
   there is no route for them here, so a plain click 404s the whole page.
   Resolve them against the open concept and navigate in-app instead; external
   links open in a new tab; anything unresolvable is disabled, never a 404. */
let shownId=null;
/* Every directory that holds a concept — the sync existence check for links
   that point at a directory or its index rather than at a concept file. */
const DIRSET=new Set();
NODES.forEach(n=>{const parts=n.id.split('/');for(let i=1;i<parts.length;i++)DIRSET.add(parts.slice(0,i).join('/'));});
/* A markdown href resolves to a concept ({id}) or to the authored layer
   ({res:{kind:'index',dir}} / {res:{kind:'log',path}}) — or to null (dead).
   Directory links (`model/`, `/`) count as that directory's index. */
function resolveTarget(href,baseId){let p=href.split('#')[0].split('?')[0];if(!p)return null;
 try{p=decodeURIComponent(p);}catch(e){}
 const out=p.charAt(0)==='/'?[]:(baseId?baseId.split('/').slice(0,-1):[]);
 for(const s of p.replace(/^\//,'').split('/')){if(!s||s==='.')continue;if(s==='..'){out.pop();continue;}out.push(s);}
 const path=out.join('/');
 const id=path.replace(/\.md$/i,'');
 if(byId[id])return {id:id};
 if(/(^|\/)index\.md$/i.test(path))return {res:{kind:'index',dir:dirOfPath(path)}};
 if(/(^|\/)log\.md$/i.test(path))return {res:{kind:'log',path:path}};
 if(path===''||DIRSET.has(path))return {res:{kind:'index',dir:path===''?'.':path}};
 return null;}
function interceptMdLinks(container,baseIdOf,go,goRes){container.addEventListener('click',e=>{
 const a=e.target.closest('a');
 if(!a||!container.contains(a)||a.hasAttribute('data-go'))return;
 const href=a.getAttribute('href')||'';
 if(/^[a-z][a-z0-9+.-]*:/i.test(href)||href.indexOf('//')===0){e.preventDefault();window.open(a.href,'_blank','noopener');return;}
 e.preventDefault();if(href.charAt(0)==='#')return;
 const t=resolveTarget(href,baseIdOf());
 if(t&&t.id)go(t.id);
 else if(t&&t.res&&goRes)goRes(t.res);
 else{a.classList.add('dead');a.title='not a file in this bundle';}});}
const ixPathOf=dir=>dir==='.'?'index.md':dir+'/index.md';
interceptMdLinks(sideBody,()=>shownId,select,r=>r.kind==='index'?showDir(r.dir):showLog(r.path));
interceptMdLinks(document.getElementById('fp-body'),()=>fileSel,id=>openFile(id),
 r=>openReserved(r.kind,r.kind==='index'?ixPathOf(r.dir):r.path));
/* Clicking a folder node (tree mode) or an area box (cluster mode) opens that
   directory's §6 index entry in the inspector: the authored map when one
   exists, the synthesized listing when not. */
function showDir(dir){getIndex().then(dirs=>{const d=dirs.find(x=>x.dir===dir);if(!d)return;
 const opened=openPanel();sideBody.scrollTop=0;
 shownId=d.dir==='.'?'index':d.dir+'/index'; /* pseudo-id: relative links in the map resolve against its directory */
 const label=d.dir==='.'?BUNDLE:d.dir+'/';
 const types=Object.entries(d.types||{}).map(([t,n])=>esc(t||'Untyped')+' '+n).join(' · ');
 sideBody.innerHTML=`<span class="type">${d.present?'index.md':'no index.md · synthesized'}</span>
  <h2 class="title">${esc(label)}</h2>
  <div class="desc">${d.count} concept${d.count===1?'':'s'}${types?' · '+types:''}</div>
  <div class="body" id="dir-body"></div>`;
 if(d.present)renderMarkdown(document.getElementById('dir-body'),d.body||'');
 else document.getElementById('dir-body').innerHTML=listingHtml(d.listing);
 sideBody.querySelectorAll('[data-go]').forEach(a=>a.onclick=()=>select(a.getAttribute('data-go')));
 if(opened)requestAnimationFrame(()=>cy.resize());});}
/* A log.md link opens the history in the inspector, fetched fresh. */
function showLog(path){LOGS=null;getLogs().then(logs=>{const l=logs.find(x=>x.path===path);if(!l)return;
 const opened=openPanel();sideBody.scrollTop=0;
 shownId=path.replace(/\.md$/,'');
 sideBody.innerHTML=`<span class="type">update log · §7</span><h2 class="title">${esc(path)}</h2><div class="body" id="dir-body"></div>`;
 renderMarkdown(document.getElementById('dir-body'),l.content||'');
 if(opened)requestAnimationFrame(()=>cy.resize());});}
/* Two per-concept reads shared by the inspector and the files preview: the raw
   markdown body (rendered client-side) and the description fragment. Live they
   hit /node and /node/meta; under EMBED the body resolves from the baked payload
   and the meta fragment is derived from the baked catalog — escaped here the same
   way /node/meta escapes it — so the description lives in exactly one place.
   Never memoized in server mode, so on-disk edits keep reflecting. */
const EMBED_DESC=EMBED?Object.fromEntries((EMBED.catalog||[]).map(c=>[c.id,c.description||''])):null;
const metaFragment=d=>(d==null||String(d).trim()==='')?'<span class="empty">no description</span>':esc(d);
function getNodeBody(id){return EMBED?Promise.resolve(EMBED.bodies[id]||''):fetch(NODE_ENDPOINT+'?id='+encodeURIComponent(id)).then(r=>r.ok?r.text():'');}
function getNodeMeta(id){return EMBED?Promise.resolve(metaFragment(EMBED_DESC[id])):fetch(META_ENDPOINT+'?id='+encodeURIComponent(id)).then(r=>r.ok?r.text():'');}
function show(id){const n=byId[id];if(!n)return false;const ty=typeOf[id]||'Untyped';const c=color[ty]||'#64748b';
 shownId=id;const opened=openPanel();sideBody.scrollTop=0;
 sideBody.innerHTML=`<button type="button" class="type facet" data-focus-type="${esc(ty)}" title="Show only ${esc(ty)} in the graph"><span class="dot" style="background:${c}"></span>${esc(ty)}</button>
 <h2 class="title">${esc(n.title||id)}</h2><div class="desc loading" id="desc">loading…</div>
 <div class="tags">${(tagsOf[id]||[]).map(t=>`<button type="button" class="tag facet" data-focus-tag="${esc(t)}" title="Show only concepts tagged ${esc(t)}">${esc(t)}</button>`).join('')}</div>
 ${relList('Links to',outL[id])}${relList('Linked from',inL[id])}<div class="body" id="body"></div>`;
 sideBody.querySelectorAll('[data-go]').forEach(a=>a.onclick=()=>select(a.getAttribute('data-go')));
 /* Focus on the way in, clear on the way back out: the chip both sets the
    filter and undoes it, so the gesture never strands you in a filtered graph
    with the way back somewhere else. The inspected concept always carries the
    facet you clicked, so it survives its own filter and the panel stays on the
    concept you were reading — which is what makes the second click reachable. */
