  const counted=SEARCH_PH[view]!==undefined&&view!=='tags';
  const qs=(q[view]||'').trim();
  let shown=null,total=null;
  if(counted){const c=view==='graph'?graphCounts():last[view];if(c){shown=c[0];total=c[1];}}
