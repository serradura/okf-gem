{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "command -v ruby >/dev/null 2>&1 && ruby \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/curate.rb\" || true",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
